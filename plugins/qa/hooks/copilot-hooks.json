{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./hooks/qa-bootstrap.sh",
        "timeoutSec": 30
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "./hooks/qa-post-implementer.sh",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "./hooks/qa-post-validator.sh",
        "timeoutSec": 30
      }
    ]
  }
}
