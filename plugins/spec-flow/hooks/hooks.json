{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "./hooks/session-start",
        "timeoutSec": 60
      }
    ]
  }
}
