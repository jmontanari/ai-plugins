#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CONFIG_FILE=".spec-flow.yaml"
if [ ! -f "$CONFIG_FILE" ]; then
  cp "${PLUGIN_ROOT}/templates/pipeline-config.yaml" "$CONFIG_FILE"
fi

doctrine_content=$(cat "${PLUGIN_ROOT}/reference/spec-flow-doctrine.md" 2>/dev/null || echo "spec-flow doctrine not found")

# Charter doctrine — load the doctrine_load-listed charter skills into session context.
# Charter lives under <charter_root>/skills/charter-<domain>/SKILL.md, where <charter_root>
# is `.github` or `.claude` (resolved from the `charter_root` config key, else by detection).
# Controlled by `charter.doctrine_load` in .spec-flow.yaml. Silent no-op if no charter skills
# exist, doctrine_load is absent/empty/[], or a listed domain isn't authored yet.
docs_root=$(grep -E '^docs_root:' "$CONFIG_FILE" 2>/dev/null | sed -E 's/^docs_root:[[:space:]]*//' | tr -d '"' | head -n1 || true)
docs_root="${docs_root:-docs}"

charter_content=""

# Resolve charter_root: explicit config key first, else detect by existence (.claude before .github).
charter_root=$(grep -E '^charter_root:' "$CONFIG_FILE" 2>/dev/null \
  | sed -E 's/^charter_root:[[:space:]]*//; s/[[:space:]]*#.*$//; s/[[:space:]]+$//' \
  | tr -d "\"'" | head -n1 || true)
if [ -z "$charter_root" ]; then
  if ls .claude/skills/charter-*/SKILL.md >/dev/null 2>&1; then
    charter_root=".claude"
  elif ls .github/skills/charter-*/SKILL.md >/dev/null 2>&1; then
    charter_root=".github"
  fi
fi

# Inject only the doctrine_load-listed domains; other domains load on demand by description.
if [ -n "$charter_root" ] && [ -d "${charter_root}/skills" ]; then
  doctrine_line=$(grep -E '^[[:space:]]+doctrine_load:' "$CONFIG_FILE" 2>/dev/null | head -n1 || true)
  doctrine_list=""
  if [ -n "$doctrine_line" ]; then
    doctrine_list=$(printf '%s' "$doctrine_line" | sed -E 's/.*\[([^]]*)\].*/\1/' | tr ',' '\n' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')
  fi
  if [ -n "$doctrine_list" ]; then
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      skill_file="${charter_root}/skills/charter-${name}/SKILL.md"
      if [ -f "$skill_file" ]; then
        charter_content+=$'\n\n--- charter/'"${name}"$' ---\n'"$(cat "$skill_file")"
      fi
    done <<< "$doctrine_list"
  fi
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

doctrine_escaped=$(escape_for_json "$doctrine_content")

charter_section=""
if [ -n "$charter_content" ]; then
  charter_escaped=$(escape_for_json "$charter_content")
  charter_section="\n\nProject Charter (binding — every spec, plan, and implementation must honor these):\n${charter_escaped}"
fi

# Detect active spec-flow worktrees and inject CWD requirement.
worktree_context=""
if command -v git >/dev/null 2>&1; then
  in_worktree=""
  in_branch=""
  main_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        wt_path="${line#worktree }"
        [ "$wt_path" = "$main_root" ] && wt_path="" || in_worktree="$wt_path"
        ;;
      branch\ refs/heads/*)
        in_branch="${line#branch refs/heads/}"
        if [ -n "$in_worktree" ] && echo "$in_branch" | grep -qE '^(piece|change|spec|plan|execute)/'; then
          wt_escaped=$(escape_for_json "$in_worktree")
          br_escaped=$(escape_for_json "$in_branch")
          worktree_context="${worktree_context}\n\n⚡ ACTIVE SPEC-FLOW WORKTREE:\n  Path:   ${wt_escaped}\n  Branch: ${br_escaped}\n  REQUIRED before any file operation: cd ${wt_escaped}\n  All reads and edits must resolve from this root — not the main repo."
        fi
        in_worktree=""
        in_branch=""
        ;;
    esac
  done < <(git worktree list --porcelain 2>/dev/null || true)
fi

plugin_root_escaped=$(escape_for_json "$PLUGIN_ROOT")

worktree_context_escaped=""
if [ -n "$worktree_context" ]; then
  worktree_context_escaped=$(escape_for_json "$worktree_context")
fi

session_context="<IMPORTANT>\nspec-flow plugin is active.\n\nBefore starting work, invoke the 'intake' skill to classify the work, set up the correct working directory, and load the appropriate context. The intake skill calls status internally — invoke intake, not status directly, when beginning any work session.\n\nProject config: \`.spec-flow.yaml\` — read it before any path operations. Use \`docs_root\` in place of \`docs/\` and \`worktrees_root\` in place of \`worktrees/\` for all paths. If the file is missing, default to \`docs\` and \`worktrees\`.\n\nPlugin root: ${plugin_root_escaped}\nWhen skill instructions reference \${CLAUDE_PLUGIN_ROOT}, resolve it to: ${plugin_root_escaped}${worktree_context_escaped}\n\nTDD Doctrine (governs all implementation work):\n\n${doctrine_escaped}${charter_section}\n</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
