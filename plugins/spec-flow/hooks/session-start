#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CONFIG_FILE=".spec-flow.yaml"
if [ ! -f "$CONFIG_FILE" ]; then
  cp "${PLUGIN_ROOT}/templates/pipeline-config.yaml" "$CONFIG_FILE"
fi

doctrine_content=$(cat "${PLUGIN_ROOT}/reference/spec-flow-doctrine.md" 2>/dev/null || echo "spec-flow doctrine not found")

# Charter doctrine (v2.0.0) — conditionally load specific charter files into session context.
# Controlled by `charter.doctrine_load` in .spec-flow.yaml. Silent no-op if:
#   - docs/charter/ doesn't exist (pre-charter project, or opted-out)
#   - charter.doctrine_load is absent, empty, or [] in config
#   - individual charter file doesn't exist (user hasn't authored it yet)
docs_root=$(grep -E '^docs_root:' "$CONFIG_FILE" 2>/dev/null | sed -E 's/^docs_root:[[:space:]]*//' | tr -d '"' | head -n1 || true)
docs_root="${docs_root:-docs}"

layout_warning=""
if [ -f "$CONFIG_FILE" ]; then
  # Strip leading `layout_version:`, trailing `# comment` (if any), surrounding whitespace, and quotes (single or double).
  layout_version=$(grep -E '^layout_version:' "$CONFIG_FILE" 2>/dev/null \
    | sed -E 's/^layout_version:[[:space:]]*//; s/[[:space:]]*#.*$//; s/[[:space:]]+$//' \
    | tr -d "\"'" | head -n1 || true)
  # Fire warning when: empty, non-integer (typos like "v3", trailing text), or numeric value < 3.
  if [ -z "$layout_version" ] \
     || ! printf '%s' "$layout_version" | grep -qE '^[0-9]+$' \
     || [ "$layout_version" -lt 3 ]; then
    layout_warning=$'\n\n⚠️  Layout is pre-v3. Run `/spec-flow:migrate` to adopt multi-PRD.'
  fi
fi

charter_content=""
charter_dir="${docs_root}/charter"
if [ -d "$charter_dir" ]; then
  doctrine_line=$(grep -E '^[[:space:]]+doctrine_load:' "$CONFIG_FILE" 2>/dev/null | head -n1 || true)
  doctrine_list=""
  if [ -n "$doctrine_line" ]; then
    doctrine_list=$(printf '%s' "$doctrine_line" | sed -E 's/.*\[([^]]*)\].*/\1/' | tr ',' '\n' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')
  fi
  if [ -n "$doctrine_list" ]; then
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      file="${charter_dir}/${name}.md"
      if [ -f "$file" ]; then
        charter_content+=$'\n\n--- charter/'"${name}.md"$' ---\n'"$(cat "$file")"
      fi
    done <<< "$doctrine_list"
  fi
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

doctrine_escaped=$(escape_for_json "$doctrine_content")

charter_section=""
if [ -n "$charter_content" ]; then
  charter_escaped=$(escape_for_json "$charter_content")
  charter_section="\n\nProject Charter (binding — every spec, plan, and implementation must honor these):\n${charter_escaped}"
fi

# Detect active spec-flow worktrees and inject CWD requirement.
worktree_context=""
if command -v git >/dev/null 2>&1; then
  in_worktree=""
  in_branch=""
  main_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        wt_path="${line#worktree }"
        [ "$wt_path" = "$main_root" ] && wt_path="" || in_worktree="$wt_path"
        ;;
      branch\ refs/heads/*)
        in_branch="${line#branch refs/heads/}"
        if [ -n "$in_worktree" ] && echo "$in_branch" | grep -qE '^(spec|plan|execute)/'; then
          wt_escaped=$(escape_for_json "$in_worktree")
          br_escaped=$(escape_for_json "$in_branch")
          worktree_context="${worktree_context}\n\n⚡ ACTIVE SPEC-FLOW WORKTREE:\n  Path:   ${wt_escaped}\n  Branch: ${br_escaped}\n  REQUIRED before any file operation: cd ${wt_escaped}\n  All reads and edits must resolve from this root — not the main repo."
        fi
        in_worktree=""
        in_branch=""
        ;;
    esac
  done < <(git worktree list --porcelain 2>/dev/null || true)
fi

layout_warning_escaped=""
if [ -n "$layout_warning" ]; then
  layout_warning_escaped=$(escape_for_json "$layout_warning")
fi

plugin_root_escaped=$(escape_for_json "$PLUGIN_ROOT")

worktree_context_escaped=""
if [ -n "$worktree_context" ]; then
  worktree_context_escaped=$(escape_for_json "$worktree_context")
fi

session_context="<IMPORTANT>\nspec-flow plugin is active.\n\nBefore starting work, invoke the 'intake' skill to classify the work, set up the correct working directory, and load the appropriate context. The intake skill calls status internally — invoke intake, not status directly, when beginning any work session.\n\nProject config: \`.spec-flow.yaml\` — read it before any path operations. Use \`docs_root\` in place of \`docs/\` and \`worktrees_root\` in place of \`worktrees/\` for all paths. If the file is missing, default to \`docs\` and \`worktrees\`.\n\nPlugin root: ${plugin_root_escaped}\nWhen skill instructions reference \${CLAUDE_PLUGIN_ROOT}, resolve it to: ${plugin_root_escaped}${worktree_context_escaped}\n\nTDD Doctrine (governs all implementation work):\n\n${doctrine_escaped}${charter_section}${layout_warning_escaped}\n</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
