#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Python fast-path dispatch
# If python3 is available (and not suppressed), exec into the Python
# implementation which is significantly faster on large manifests.
# Set MANIFEST_QUERY_NO_PY=1 to force the awk/bash path (e.g., for testing).
# NN-C-005: the awk path below is the mandatory fallback when python3 is absent.
# ---------------------------------------------------------------------------
# M2: Resolve the REAL directory of this script, following symlinks.
# Using BASH_SOURCE[0] + readlink loop handles the case where the tool is
# invoked via a PATH symlink (where $0 points to the symlink, not the source).
_resolve_real_dir() {
  local src="${BASH_SOURCE[0]}"
  # Follow symlinks until we reach the real file
  while [ -L "$src" ]; do
    local link_dir
    link_dir="$(CDPATH= cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink "$src")"
    # Handle relative symlink targets
    case "$src" in
      /*) ;;
      *) src="${link_dir}/${src}" ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$src")" && pwd
}
_REAL_SCRIPT_DIR="$(_resolve_real_dir)"
_PY_SCRIPT="${_REAL_SCRIPT_DIR}/manifest-query.py"

# M2: Guard the exec — if .py is missing, fall through to awk path (no hard-fail)
if command -v python3 >/dev/null 2>&1 && [ -z "${MANIFEST_QUERY_NO_PY:-}" ] && [ -f "$_PY_SCRIPT" ]; then
  exec python3 "$_PY_SCRIPT" "$@"
fi

# manifest-query — query and mutate spec-flow manifest.yaml files
#
# Usage: manifest-query <subcommand> [args] --file <path>
#
# Subcommands:
#   open                       — print slugs where status != merged, in manifest order
#   deps <slug>                — print that slug's dependencies, one per line
#   deps <slug> --reverse      — print slugs whose deps include <slug>
#   ready                      — print slugs where status==open AND every dep is merged
#   table                      — aligned columns: slug | status | deps | prd_sections
#   set-status <slug> <new>    — rewrite that piece's status: line in-place
#
# --file is required; error with usage (exit 64) when absent.

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat >&2 <<'EOF'
Usage: manifest-query <subcommand> [args] --file <path>

Subcommands:
  open                       List slugs where status != merged (manifest order)
  deps <slug>                List dependencies of <slug>
  deps <slug> --reverse      List slugs that depend on <slug>
  ready                      List slugs: status==open AND all deps are merged
  table                      Aligned table: slug | status | deps | prd_sections
  set-status <slug> <new>    Update <slug>'s status field in-place

Status vocabulary: open, specced, planned, in-progress, merged, done, superseded, blocked

--file <path>  Required. Path to manifest.yaml.
EOF
  exit 64
}

# ---------------------------------------------------------------------------
# Arg parsing
# ---------------------------------------------------------------------------
SUBCMD=""
MANIFEST_FILE=""
ARG1=""
ARG2=""
REVERSE=0

POSITIONALS=()
i=0
args=("$@")
while [ $i -lt ${#args[@]} ]; do
  arg="${args[$i]}"
  case "$arg" in
    --file)
      i=$(( i + 1 ))
      # S5: bounds-check before reading to avoid unbound variable crash under set -u
      if [ "$i" -ge "${#args[@]}" ]; then
        echo "Error: --file requires a path argument" >&2
        usage
      fi
      MANIFEST_FILE="${args[$i]}"
      ;;
    --reverse)
      REVERSE=1
      ;;
    *)
      POSITIONALS+=("$arg")
      ;;
  esac
  i=$(( i + 1 ))
done

[ ${#POSITIONALS[@]} -ge 1 ] && SUBCMD="${POSITIONALS[0]}"
[ ${#POSITIONALS[@]} -ge 2 ] && ARG1="${POSITIONALS[1]}"
[ ${#POSITIONALS[@]} -ge 3 ] && ARG2="${POSITIONALS[2]}"

# Validate --file
if [ -z "$MANIFEST_FILE" ]; then
  echo "Error: --file is required" >&2
  usage
fi

if [ ! -f "$MANIFEST_FILE" ]; then
  echo "Error: file not found: $MANIFEST_FILE" >&2
  exit 2
fi

if [ -z "$SUBCMD" ]; then
  usage
fi

# ---------------------------------------------------------------------------
# Status vocabulary
# ---------------------------------------------------------------------------
STATUS_VOCAB="open specced planned in-progress merged done superseded blocked"

is_valid_status() {
  local s="$1"
  for v in $STATUS_VOCAB; do
    if [ "$s" = "$v" ]; then
      return 0
    fi
  done
  return 1
}

# ---------------------------------------------------------------------------
# AWK parser
#
# Parses pieces from the manifest. Outputs TSV: slug TAB status TAB deps TAB prd_sections
#
# Rules:
#   - A piece begins at "^  - name:" or "^  - slug:" (2-space list item)
#   - Fields are at 4-space indentation: "^    <key>:"
#   - "description: |" starts a literal block; its content lines have >=6 spaces
#   - Exit the description block when indentation drops to <=4 spaces (field level)
#   - Stop parsing pieces at top-level "^coverage:"
# ---------------------------------------------------------------------------
AWK_PARSE='
BEGIN {
  OFS = "\t"
  in_piece    = 0
  in_desc     = 0
  in_deps     = 0
  in_prd      = 0
  piece_count = 0
  slug = ""; status = ""; deps = ""; prd = ""; init_name = ""
}

# Top-level key ends piece parsing
/^coverage:/ || /^[a-z_]+:/ {
  if (/^pieces:/) { next }
  if (in_piece) { save_piece() }
  in_piece = 0
  in_desc  = 0
  in_deps  = 0
  in_prd   = 0
  next
}

# New list item — beginning of a piece (M6: recognize ANY "  - <key>:" opener)
/^  - [a-z_]+:/ {
  if (in_piece) { save_piece() }
  in_piece  = 1
  in_desc   = 0
  in_deps   = 0
  in_prd    = 0
  slug      = ""
  init_name = ""
  status    = ""
  deps      = ""
  prd       = ""
  # Extract the key and value from this opener line
  val = $0
  sub(/^  - [a-z_]+:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if ($0 ~ /^  - slug:/) {
    slug = val
  } else if ($0 ~ /^  - name:/) {
    init_name = val
  } else if ($0 ~ /^  - status:/) {
    # Strip inline comment before assigning (M5)
    sub(/[[:space:]]+#.*$/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    status = val
  } else if ($0 ~ /^  - (dependencies|depends_on):/) {
    val2 = $0; sub(/^  - (dependencies|depends_on):[[:space:]]*/, "", val2)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
    sub(/[[:space:]]+#.*$/, "", val2)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
    if (val2 == "" || val2 == "[]") {
      if (val2 == "[]") { deps = "" } else { in_deps = 1 }
    } else {
      sub(/^\[/, "", val2); sub(/\]$/, "", val2)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
      deps = val2
    }
  } else if ($0 ~ /^  - prd_sections:/) {
    val2 = $0; sub(/^  - prd_sections:[[:space:]]*/, "", val2)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
    sub(/[[:space:]]+#.*$/, "", val2)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
    if (val2 == "" || val2 == "[]") {
      if (val2 == "[]") { prd = "" } else { in_prd = 1 }
    } else {
      sub(/^\[/, "", val2); sub(/\]$/, "", val2)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", val2)
      prd = val2
    }
  }
  next
}

# Skip non-piece lines
!in_piece { next }

# Detect start of description literal block (field at 4-space, value is "|")
/^    description:[[:space:]]*[|>][[:space:]]*$/ {
  in_desc = 1
  in_deps = 0
  in_prd  = 0
  next
}

# While inside a description block: skip lines with >4 spaces (block content)
# Exit block when we see a line with exactly 4 spaces (another field)
in_desc {
  # Count leading spaces
  line = $0
  spaces = 0
  while (substr(line, 1, 1) == " ") { spaces++; line = substr(line, 2) }
  if (spaces <= 4 && length($0) > 0) {
    # Back at field level — exit description block and fall through
    in_desc = 0
  } else {
    next
  }
}

# Block-style list items under deps (6-space "      - item")
in_deps && /^      - / {
  val = $0; sub(/^      -[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  # Strip inline comments (e.g. "# comment")
  sub(/[[:space:]]+#.*$/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if (val != "") {
    if (deps == "") { deps = val } else { deps = deps ", " val }
  }
  next
}

# Block-style list items under prd_sections (6-space "      - item")
in_prd && /^      - / {
  val = $0; sub(/^      -[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  # Strip inline comments (e.g. "# comment")
  sub(/[[:space:]]+#.*$/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if (val != "") {
    if (prd == "") { prd = val } else { prd = prd ", " val }
  }
  next
}

# Exit block-style deps/prd collection when we return to field level (4-space)
# or higher structure
(in_deps || in_prd) && /^    [^ ]/ {
  in_deps = 0
  in_prd  = 0
  # fall through to process this field line
}

# Field captures (4-space indented)
/^    slug:/ {
  in_deps = 0; in_prd = 0
  val = $0; sub(/^    slug:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  slug = val
  next
}

/^    name:/ {
  in_deps = 0; in_prd = 0
  val = $0; sub(/^    name:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if (init_name == "") init_name = val
  next
}

/^    status:/ {
  in_deps = 0; in_prd = 0
  val = $0; sub(/^    status:[[:space:]]*/, "", val)
  # M5: strip inline trailing comment before whitespace trim
  sub(/[[:space:]]+#.*$/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  status = val
  next
}

# dependencies: or depends_on: — inline form [ ] or block form (no value on line)
/^    (dependencies|depends_on):/ {
  in_prd  = 0
  val = $0; sub(/^    (dependencies|depends_on):[[:space:]]*/, "", val)
  # M5: strip inline trailing comment BEFORE bracket/whitespace stripping
  sub(/[[:space:]]+#.*$/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if (val == "" || val == "[]") {
    # empty or will be filled by block-style items
    if (val == "[]") {
      deps = ""
    } else {
      # block-style: enter collection mode
      in_deps = 1
    }
  } else {
    # inline: [item, item] or bare items
    in_deps = 0
    sub(/^\[/, "", val); sub(/\]$/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    deps = val
  }
  next
}

/^    prd_sections:/ {
  in_deps = 0
  val = $0; sub(/^    prd_sections:[[:space:]]*/, "", val)
  # M5: strip inline trailing comment BEFORE bracket/whitespace stripping
  sub(/[[:space:]]+#.*$/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  if (val == "" || val == "[]") {
    if (val == "[]") {
      prd = ""
    } else {
      in_prd = 1
    }
  } else {
    in_prd = 0
    sub(/^\[/, "", val); sub(/\]$/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    prd = val
  }
  next
}

function save_piece(    effective) {
  effective = (slug != "") ? slug : init_name
  slugs[piece_count]    = effective
  statuses[piece_count] = status
  deplist[piece_count]  = deps
  prdlist[piece_count]  = prd
  piece_count++
}

END {
  if (in_piece) { save_piece() }
  for (i = 0; i < piece_count; i++) {
    print slugs[i], statuses[i], deplist[i], prdlist[i]
  }
}
'

parse_manifest() {
  awk "$AWK_PARSE" "$MANIFEST_FILE"
}

# ---------------------------------------------------------------------------
# Subcommand: open
# ---------------------------------------------------------------------------
cmd_open() {
  parse_manifest | awk -F'\t' '$2 != "merged" && $2 != "" { print $1 }
                               $2 == "" && $1 != ""        { print $1 }'
}

# ---------------------------------------------------------------------------
# Subcommand: deps
# ---------------------------------------------------------------------------
cmd_deps() {
  local target="$1"
  local reverse="$2"

  # Parse all pieces into temp storage via awk
  local parsed
  parsed="$(parse_manifest)"

  if [ "$reverse" -eq 0 ]; then
    # Use awk -F'\t' to correctly handle empty fields (bash read collapses consecutive tabs)
    local found
    found="$(printf '%s\n' "$parsed" | awk -F'\t' -v target="$target" '
      $1 == target { found=1; print $3; exit }
      END { if (!found) exit 1 }
    ')" || { echo "Error: unknown slug: $target" >&2; exit 2; }
    # Split comma-separated deps and print one per line
    if [ -n "$found" ]; then
      printf '%s\n' "$found" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^$' || true
    fi
  else
    # Check target slug exists
    local exists
    exists="$(printf '%s\n' "$parsed" | awk -F'\t' -v target="$target" '$1 == target {found=1; exit} END {exit !found}')" || {
      echo "Error: unknown slug: $target" >&2
      exit 2
    }
    # Print slugs that depend on target
    printf '%s\n' "$parsed" | awk -F'\t' -v target="$target" '
    {
      s  = $1
      d  = $3
      if (d == "") next
      n = split(d, arr, /,[[:space:]]*/);
      for (j = 1; j <= n; j++) {
        dep = arr[j]
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", dep)
        if (dep == target) { print s; break }
      }
    }
    '
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: ready
#
# ready = status==open AND every dep's status is "merged" or "done"
# Uses a two-pass approach with awk to avoid bash associative arrays
# (macOS ships bash 3.2 which doesn't support declare -A)
# ---------------------------------------------------------------------------
cmd_ready() {
  parse_manifest | awk -F'\t' '
  BEGIN { count = 0 }
  {
    slugs[count]    = $1
    statuses[count] = $2
    deplist[count]  = $3
    count++
  }
  END {
    # Build slug->status lookup
    for (i = 0; i < count; i++) {
      status_of[slugs[i]] = statuses[i]
    }
    # Print pieces where status==open and all deps are merged/done
    for (i = 0; i < count; i++) {
      if (statuses[i] != "open") continue
      deps = deplist[i]
      ready = 1
      if (deps != "") {
        n = split(deps, arr, /,[[:space:]]*/);
        for (j = 1; j <= n; j++) {
          dep = arr[j]
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", dep)
          if (dep == "") continue
          ds = status_of[dep]
          if (ds != "merged" && ds != "done") {
            ready = 0
            break
          }
        }
      }
      if (ready) print slugs[i]
    }
  }
  '
}

# ---------------------------------------------------------------------------
# Subcommand: table
# ---------------------------------------------------------------------------
cmd_table() {
  parse_manifest | awk -F'\t' '
  BEGIN { count = 0 }
  {
    row_slug[count]   = $1
    row_status[count] = $2
    row_deps[count]   = $3
    row_prd[count]    = $4
    count++
  }
  END {
    # Compute column widths
    w_slug = 4; w_status = 6; w_deps = 4; w_prd = 12
    for (i = 0; i < count; i++) {
      if (length(row_slug[i])   > w_slug)   w_slug   = length(row_slug[i])
      if (length(row_status[i]) > w_status) w_status = length(row_status[i])
      if (length(row_deps[i])   > w_deps)   w_deps   = length(row_deps[i])
      if (length(row_prd[i])    > w_prd)    w_prd    = length(row_prd[i])
    }
    # Header
    fmt = "%-" w_slug "s  %-" w_status "s  %-" w_deps "s  %s\n"
    printf fmt, "slug", "status", "deps", "prd_sections"
    # Separator
    dash_slug = ""; for (k=0;k<w_slug;k++)   dash_slug   = dash_slug "-"
    dash_st   = ""; for (k=0;k<w_status;k++) dash_st     = dash_st   "-"
    dash_deps = ""; for (k=0;k<w_deps;k++)   dash_deps   = dash_deps "-"
    dash_prd  = ""; for (k=0;k<w_prd;k++)    dash_prd    = dash_prd  "-"
    printf fmt, dash_slug, dash_st, dash_deps, dash_prd
    # Data rows
    for (i = 0; i < count; i++) {
      printf fmt, row_slug[i], row_status[i], row_deps[i], row_prd[i]
    }
  }
  '
}

# ---------------------------------------------------------------------------
# Subcommand: set-status
# ---------------------------------------------------------------------------
cmd_set_status() {
  local target="$1"
  local new_status="$2"

  # Validate status value
  if ! is_valid_status "$new_status"; then
    echo "Error: unknown status: '$new_status'. Valid: $STATUS_VOCAB" >&2
    exit 2
  fi

  # Verify slug exists in the manifest (use awk -F'\t' to handle empty fields correctly)
  local found
  found="$(parse_manifest | awk -F'\t' -v target="$target" '$1 == target {found=1; exit} END {exit !found}')" || {
    echo "Error: unknown slug: $target" >&2
    exit 2
  }

  # S4: Resolve symlinks in MANIFEST_FILE so we write through to the real file
  # (atomic replace on a symlink would detach it; we want to update the target).
  local real_manifest
  real_manifest="$(python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$MANIFEST_FILE" 2>/dev/null || \
    perl -e 'use Cwd "abs_path"; print abs_path($ARGV[0])' "$MANIFEST_FILE" 2>/dev/null || \
    echo "$MANIFEST_FILE")"

  # M1/S3: Create temp file in the SAME directory as the target to avoid
  # cross-device rename (tmpfile in $TMPDIR on a different fs than the manifest).
  local manifest_dir
  manifest_dir="$(CDPATH= cd -- "$(dirname -- "$real_manifest")" && pwd)"
  local tmpfile
  tmpfile="$(mktemp "${manifest_dir}/.mq-setstatus-XXXXXX")"

  # S1: Trap to clean up temp file on exit/error
  trap 'rm -f "$tmpfile"' EXIT

  # S3: Preserve original file mode on the temp file before writing
  local orig_mode
  orig_mode="$(stat -f '%Lp' "$real_manifest" 2>/dev/null || stat -c '%a' "$real_manifest" 2>/dev/null || echo 644)"
  chmod "$orig_mode" "$tmpfile"

  awk -v target="$target" -v newval="$new_status" '
  BEGIN {
    in_piece     = 0
    in_desc      = 0
    matched_done = 0
    slug_val     = ""
    init_name    = ""
    # M6: buffer lines emitted before we know the effective slug.
    # buf[] holds lines; buf_status_idx holds which buffer index is the opener
    # status line (if any); id_known = 1 once slug or name has been seen.
    buf_count    = 0
    buf_status_idx = -1
    id_known     = 0
  }

  function flush_buf(    i) {
    for (i = 0; i < buf_count; i++) print buf[i]
    buf_count = 0
    buf_status_idx = -1
    id_known = 0
  }

  function emit(line) {
    if (!id_known) {
      buf[buf_count++] = line
    } else {
      print line
    }
  }

  # Once we know the effective slug, check if any buffered status line needs
  # rewriting, then flush the buffer.
  function resolve_id(    effective, i, rewritten) {
    effective = (slug_val != "") ? slug_val : init_name
    if (buf_status_idx >= 0 && effective == target && !matched_done) {
      rewritten = buf[buf_status_idx]
      sub(/status:[[:space:]]*.*$/, "status: " newval, rewritten)
      buf[buf_status_idx] = rewritten
      matched_done = 1
    }
    id_known = 1
    flush_buf()
  }

  # Stop piece tracking at coverage block
  /^coverage:/ || (/^[a-z_]+:/ && !/^pieces:/) {
    flush_buf()
    in_piece = 0
    in_desc  = 0
    print
    next
  }

  /^pieces:/ { flush_buf(); print; next }

  # New list item (M6: recognize ANY "  - <key>:" opener)
  /^  - [a-z_]+:/ {
    flush_buf()
    in_piece     = 1
    in_desc      = 0
    slug_val     = ""
    init_name    = ""
    buf_status_idx = -1
    id_known     = 0
    val = $0
    sub(/^  - [a-z_]+:[[:space:]]*/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    if ($0 ~ /^  - slug:/) {
      slug_val = val
      id_known = 1
      print
    } else if ($0 ~ /^  - name:/) {
      init_name = val
      id_known = 1
      print
    } else if ($0 ~ /^  - status:/) {
      # Status-first piece: buffer this line; mark it as the candidate status line
      buf[buf_count] = $0
      buf_status_idx = buf_count
      buf_count++
    } else {
      # Some other opener (e.g. dependencies) — buffer until id known
      buf[buf_count++] = $0
    }
    next
  }

  !in_piece { flush_buf(); print; next }

  /^    description:[[:space:]]*\|[[:space:]]*$/ {
    in_desc = 1
    emit($0)
    next
  }

  in_desc {
    line = $0; spaces = 0
    while (substr(line,1,1) == " ") { spaces++; line = substr(line,2) }
    if (spaces <= 4 && length($0) > 0) {
      in_desc = 0
      # fall through
    } else {
      emit($0)
      next
    }
  }

  /^    slug:/ {
    val = $0; sub(/^    slug:[[:space:]]*/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    slug_val = val
    if (!id_known) resolve_id()
    print
    next
  }

  /^    name:/ {
    val = $0; sub(/^    name:[[:space:]]*/, "", val)
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
    if (init_name == "") init_name = val
    if (!id_known) resolve_id()
    print
    next
  }

  /^    status:/ {
    effective = (slug_val != "") ? slug_val : init_name
    if (effective == target && !matched_done) {
      # Preserve original indentation, rewrite only the value
      sub(/status:[[:space:]]*.*$/, "status: " newval)
      matched_done = 1
    }
    print
    next
  }

  { emit($0) }

  END { flush_buf() }
  ' "$real_manifest" > "$tmpfile"

  mv "$tmpfile" "$real_manifest"
  trap - EXIT
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "$SUBCMD" in
  open)
    cmd_open
    ;;
  deps)
    if [ -z "$ARG1" ]; then
      echo "Error: deps requires a slug argument" >&2
      usage
    fi
    cmd_deps "$ARG1" "$REVERSE"
    ;;
  ready)
    cmd_ready
    ;;
  table)
    cmd_table
    ;;
  set-status)
    if [ -z "$ARG1" ] || [ -z "$ARG2" ]; then
      echo "Error: set-status requires <slug> and <new-status> arguments" >&2
      usage
    fi
    cmd_set_status "$ARG1" "$ARG2"
    ;;
  *)
    echo "Error: unknown subcommand: '$SUBCMD'" >&2
    usage
    ;;
esac
