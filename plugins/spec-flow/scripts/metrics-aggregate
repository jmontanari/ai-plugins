#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Python fast-path dispatch
# If python3 is available (and not suppressed), exec into the Python
# implementation which is faster on large PRDs.
# Set METRICS_AGG_NO_PY=1 to force the awk/bash path (e.g., for testing).
# NN-C-002: the awk path below is the mandatory fallback when python3 is absent.
# ---------------------------------------------------------------------------
# Resolve the REAL directory of this script, following symlinks.
# Using BASH_SOURCE[0] + readlink loop handles the case where the tool is
# invoked via a PATH symlink (where $0 points to the symlink, not the source).
_resolve_real_dir() {
  local src="${BASH_SOURCE[0]}"
  # Follow symlinks until we reach the real file
  while [ -L "$src" ]; do
    local link_dir
    link_dir="$(CDPATH= cd -- "$(dirname -- "$src")" && pwd)"
    src="$(readlink "$src")"
    # Handle relative symlink targets
    case "$src" in
      /*) ;;
      *) src="${link_dir}/${src}" ;;
    esac
  done
  CDPATH= cd -- "$(dirname -- "$src")" && pwd
}
_REAL_SCRIPT_DIR="$(_resolve_real_dir)"
_PY="${_REAL_SCRIPT_DIR}/metrics-aggregate.py"

# Guard the exec — if .py is missing, fall through to awk path (no hard-fail)
if [ "${METRICS_AGG_NO_PY:-0}" != "1" ] && command -v python3 >/dev/null 2>&1 && [ -f "$_PY" ]; then
  exec python3 "$_PY" "$@"
fi

# ---------------------------------------------------------------------------
# awk/bash fallback path
# Drop -e for the fallback: a malformed piece must not abort the whole run.
# set -uo pipefail remains active for unbound variables and pipe errors.
# ---------------------------------------------------------------------------
set +e
set -uo pipefail

PRD_SLUG="${1:?usage: metrics-aggregate <prd-slug>}"

# Reject PRD_SLUG with path separators or leading dot (CWE-22)
if [[ "$PRD_SLUG" == */* ]] || [[ "$PRD_SLUG" == .* ]]; then
    echo "metrics-aggregate: rejected unsafe prd-slug: ${PRD_SLUG}" >&2
    echo "SC-001 pass=0 total=0 population=research-artifact"
    echo "SC-002 rate=0.00 threshold=0.80 pass=false population=concreteness-floor"
    echo "SC-003 trend=insufficient-data"
    echo "SC-004 resume_rate=1.00 sonnet_default_all=true pass=false"
    echo "SC-005 trend=insufficient-data"
    echo "SC-006 repeat_scope_sum=0 pass=false"
    exit 0
fi

DOCS_ROOT="${DOCS_ROOT:-docs}"
MANIFEST="${DOCS_ROOT}/prds/${PRD_SLUG}/manifest.yaml"

if [ ! -f "$MANIFEST" ]; then
  echo "metrics-aggregate: manifest not found: $MANIFEST" >&2
  # Emit SC lines with zero/empty data and exit 0
  echo "SC-001 pass=0 total=0 population=research-artifact"
  echo "SC-002 rate=0.00 threshold=0.80 pass=false population=concreteness-floor"
  echo "SC-003 trend=insufficient-data"
  echo "SC-004 resume_rate=1.00 sonnet_default_all=true pass=true"
  echo "SC-005 trend=insufficient-data"
  echo "SC-006 repeat_scope_sum=0 pass=true"
  exit 0
fi

# ---------------------------------------------------------------------------
# Read piece slugs from manifest in file order
# Parse `slug:` lines from under the `pieces:` block
# ---------------------------------------------------------------------------
PIECE_SLUGS="$(awk '
BEGIN { in_pieces = 0 }
/^pieces:/ { in_pieces = 1; next }
in_pieces && /^[a-z_]+:/ { in_pieces = 0; next }
in_pieces && /^  - / {
  # New list item — reset slug
  slug = ""
}
in_pieces && /slug:/ {
  val = $0
  sub(/.*slug:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  if (val != "") print val
}
' "$MANIFEST")"

if [ -z "$PIECE_SLUGS" ]; then
  echo "metrics-aggregate: no pieces found in $MANIFEST" >&2
  echo "SC-001 pass=0 total=0 population=research-artifact"
  echo "SC-002 rate=0.00 threshold=0.80 pass=false population=concreteness-floor"
  echo "SC-003 trend=insufficient-data"
  echo "SC-004 resume_rate=1.00 sonnet_default_all=true pass=true"
  echo "SC-005 trend=insufficient-data"
  echo "SC-006 repeat_scope_sum=0 pass=true"
  exit 0
fi

# ---------------------------------------------------------------------------
# For each piece, attempt to parse metrics.yaml using awk
# Build arrays by emitting tab-separated records
# ---------------------------------------------------------------------------

# We'll accumulate per-piece data into a temporary file for aggregation
_TMPDIR="$(mktemp -d)"
trap 'rm -rf "$_TMPDIR"' EXIT

_RECORDS="${_TMPDIR}/records"
_ABSENT="${_TMPDIR}/absent"
touch "$_RECORDS" "$_ABSENT"

# AWK parser for a single metrics.yaml file
# Outputs a single TSV line with fields:
#   research_artifact TAB qa_rounds TAB concreteness_floor TAB
#   phases_total TAB phases_clean_sonnet TAB discoveries_unmarked TAB
#   spikes_planned TAB spikes_scope TAB repeat_scope TAB
#   sonnet_default TAB resume_clean TAB resume_total
METRICS_AWK='
BEGIN {
  OFS = "\t"
  # defaults
  research_artifact = "false"
  qa_rounds         = 0
  concreteness_floor = ""
  phases_total      = 0
  phases_clean      = 0
  disc_unmarked     = 0
  spikes_planned    = 0
  spikes_scope      = 0
  repeat_scope      = 0
  sonnet_default    = "false"
  resume_clean      = 0
  resume_total      = 0
  # state
  section    = ""   # spec | plan | execute | final_review
  subsection = ""   # phases | discoveries | spikes | amendments | resume
  schema_version_seen = 0
}

# schema_version presence check
/^schema_version:/ { schema_version_seen = 1; next }

# Top-level section detection
/^spec:$/          { section = "spec";         subsection = ""; next }
/^plan:$/          { section = "plan";         subsection = ""; next }
/^execute:$/       { section = "execute";      subsection = ""; next }
/^final_review:$/  { section = "final_review"; subsection = ""; next }
/^[a-z_]+:$/      { section = "";             subsection = ""; next }

# Sub-section detection under execute
section == "execute" && /^  phases:$/      { subsection = "phases";      next }
section == "execute" && /^  discoveries:$/ { subsection = "discoveries"; next }
section == "execute" && /^  spikes:$/      { subsection = "spikes";      next }
section == "execute" && /^  amendments:$/  { subsection = "amendments";  next }
section == "execute" && /^  resume:$/      { subsection = "resume";      next }
# Any 2-space field under execute that is not a known subsection resets subsection
section == "execute" && /^  [a-z_]+:/ && !/^  (phases|discoveries|spikes|amendments|resume):/ {
  subsection = ""
}

# spec fields
section == "spec" && /^  research_artifact:/ {
  val = $0; sub(/.*research_artifact:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  research_artifact = val
  next
}
section == "spec" && /^  qa_rounds:/ {
  val = $0; sub(/.*qa_rounds:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  qa_rounds = val + 0
  next
}

# plan fields
section == "plan" && /^  concreteness_floor:/ {
  val = $0; sub(/.*concreteness_floor:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  concreteness_floor = val
  next
}

# execute top-level fields
section == "execute" && subsection == "" && /^  sonnet_default:/ {
  val = $0; sub(/.*sonnet_default:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  sonnet_default = val
  next
}

# execute.phases fields
section == "execute" && subsection == "phases" && /^    total:/ {
  val = $0; sub(/.*total:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  phases_total = val + 0
  next
}
section == "execute" && subsection == "phases" && /^    clean_sonnet:/ {
  val = $0; sub(/.*clean_sonnet:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  phases_clean = val + 0
  next
}

# execute.discoveries fields
section == "execute" && subsection == "discoveries" && /^    unmarked:/ {
  val = $0; sub(/.*unmarked:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  disc_unmarked = val + 0
  next
}

# execute.spikes fields
section == "execute" && subsection == "spikes" && /^    planned:/ {
  val = $0; sub(/.*planned:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  spikes_planned = val + 0
  next
}
section == "execute" && subsection == "spikes" && /^    scope:/ {
  val = $0; sub(/.*scope:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  spikes_scope = val + 0
  next
}

# execute.amendments fields
section == "execute" && subsection == "amendments" && /^    repeat_scope:/ {
  val = $0; sub(/.*repeat_scope:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  repeat_scope = val + 0
  next
}

# execute.resume — list items with outcome field
section == "execute" && subsection == "resume" && /^    - at:/ {
  resume_total++
  next
}
section == "execute" && subsection == "resume" && /^      outcome:/ {
  val = $0; sub(/.*outcome:[[:space:]]*/, "", val)
  gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
  sub(/[[:space:]]*#.*$/, "", val)
  if (val == "clean") resume_clean++
  next
}

END {
  # If schema_version: was never seen, this is not a valid metrics.yaml — emit sentinel
  if (!schema_version_seen) {
    print "NOSCHEMA"
    exit 0
  }
  print research_artifact, qa_rounds, concreteness_floor, \
        phases_total, phases_clean, disc_unmarked, \
        spikes_planned, spikes_scope, repeat_scope, \
        sonnet_default, resume_clean, resume_total
}
'

while IFS= read -r piece_slug; do
  # Reject slugs containing path separators or starting with '.' (CWE-22)
  if [[ "$piece_slug" == */* ]] || [[ "$piece_slug" == .* ]]; then
    echo "metrics-aggregate: rejected unsafe slug: ${piece_slug}" >&2
    continue
  fi
  MFILE="${DOCS_ROOT}/prds/${PRD_SLUG}/specs/${piece_slug}/metrics.yaml"
  if [ ! -f "$MFILE" ]; then
    echo "metrics-aggregate: no metrics.yaml for ${PRD_SLUG}/${piece_slug}" >&2
    echo "ABSENT ${PRD_SLUG}/${piece_slug}" >> "$_ABSENT"
    continue
  fi
  # Parse the metrics file; on any awk error, treat as absent
  RECORD="$(awk "$METRICS_AWK" "$MFILE" 2>/dev/null)" || true
  if [ -z "$RECORD" ] || [ "$RECORD" = "NOSCHEMA" ]; then
    echo "metrics-aggregate: failed to parse metrics.yaml for ${PRD_SLUG}/${piece_slug}" >&2
    echo "ABSENT ${PRD_SLUG}/${piece_slug}" >> "$_ABSENT"
    continue
  fi
  # Validate record has expected number of fields (12 tab-separated)
  FIELD_COUNT="$(printf '%s' "$RECORD" | awk -F'\t' '{print NF}')"
  if [ "$FIELD_COUNT" -ne 12 ]; then
    echo "metrics-aggregate: malformed record for ${PRD_SLUG}/${piece_slug} (fields: $FIELD_COUNT)" >&2
    echo "ABSENT ${PRD_SLUG}/${piece_slug}" >> "$_ABSENT"
    continue
  fi
  printf '%s\n' "$RECORD" >> "$_RECORDS"
done <<< "$PIECE_SLUGS"

# ---------------------------------------------------------------------------
# Aggregate and emit SC-001..SC-006
# ---------------------------------------------------------------------------
awk -F'\t' -v prd="$PRD_SLUG" '
BEGIN {
  # SC-001
  sc1_pass  = 0
  sc1_total = 0
  # SC-002
  sc2_clean_sum = 0
  sc2_total_sum = 0
  # SC-003 / SC-005: collect per-piece values in order
  n = 0
  # SC-004
  sc4_resume_clean  = 0
  sc4_resume_total  = 0
  sc4_sonnet_all    = 1   # assume true until proven false
  sc4_instrumented  = 0   # count of instrumented pieces
  # SC-006
  sc6_repeat_scope = 0
}
{
  research_artifact = $1
  qa_rounds         = $2 + 0
  concreteness_floor = $3
  phases_total      = $4 + 0
  phases_clean      = $5 + 0
  disc_unmarked     = $6 + 0
  spikes_planned    = $7 + 0
  spikes_scope      = $8 + 0
  repeat_scope      = $9 + 0
  sonnet_default    = $10
  resume_clean      = $11 + 0
  resume_total      = $12 + 0

  # SC-001: population = research_artifact == true
  if (research_artifact == "true") {
    sc1_total++
    if (qa_rounds <= 3) sc1_pass++
  }

  # SC-002: population = concreteness_floor == passed
  if (concreteness_floor == "passed") {
    sc2_clean_sum += phases_clean
    sc2_total_sum += phases_total
  }

  # SC-003 / SC-005: store per-piece sums indexed by manifest order
  disc_arr[n]   = disc_unmarked
  spikes_arr[n] = spikes_planned + spikes_scope
  n++

  # SC-004
  sc4_resume_clean += resume_clean
  sc4_resume_total += resume_total
  if (sonnet_default != "true") sc4_sonnet_all = 0
  sc4_instrumented++

  # SC-006
  sc6_repeat_scope += repeat_scope
}
END {
  # SC-001
  printf "SC-001 pass=%d total=%d population=research-artifact\n", sc1_pass, sc1_total

  # SC-002
  if (sc2_total_sum == 0) {
    sc2_rate = 0.0
    sc2_pass = "false"
  } else {
    sc2_rate = sc2_clean_sum / sc2_total_sum
    sc2_pass = (sc2_rate >= 0.80) ? "true" : "false"
  }
  printf "SC-002 rate=%.2f threshold=0.80 pass=%s population=concreteness-floor\n", sc2_rate, sc2_pass

  # SC-003
  if (n < 2) {
    print "SC-003 trend=insufficient-data"
  } else {
    half = int(n / 2)
    f_sum = 0
    for (i = 0; i < half; i++) f_sum += disc_arr[i]
    s_sum = 0
    for (i = n - half; i < n; i++) s_sum += disc_arr[i]
    if (s_sum < f_sum) trend3 = "down"
    else if (s_sum > f_sum) trend3 = "up"
    else trend3 = "flat"
    printf "SC-003 first=%d second=%d trend=%s\n", f_sum, s_sum, trend3
  }

  # SC-004
  if (sc4_instrumented == 0) {
    print "SC-004 trend=insufficient-data"
  } else {
    if (sc4_resume_total == 0) {
      sc4_rate = 1.0
    } else {
      sc4_rate = sc4_resume_clean / sc4_resume_total
    }
    sc4_sonnet_str = (sc4_sonnet_all) ? "true" : "false"
    # Use integer equality to avoid float precision issues (Fix 5)
    sc4_resume_ok = (sc4_resume_total == 0 || sc4_resume_clean == sc4_resume_total)
    sc4_pass = (sc4_resume_ok && sc4_sonnet_all) ? "true" : "false"
    printf "SC-004 resume_rate=%.2f sonnet_default_all=%s pass=%s\n", sc4_rate, sc4_sonnet_str, sc4_pass
  }

  # SC-005
  if (n < 2) {
    print "SC-005 trend=insufficient-data"
  } else {
    half = int(n / 2)
    f_sum5 = 0
    for (i = 0; i < half; i++) f_sum5 += spikes_arr[i]
    s_sum5 = 0
    for (i = n - half; i < n; i++) s_sum5 += spikes_arr[i]
    if (s_sum5 < f_sum5) trend5 = "down"
    else if (s_sum5 > f_sum5) trend5 = "up"
    else trend5 = "flat"
    printf "SC-005 first=%d second=%d trend=%s\n", f_sum5, s_sum5, trend5
  }

  # SC-006
  sc6_pass = (sc6_repeat_scope == 0) ? "true" : "false"
  printf "SC-006 repeat_scope_sum=%d pass=%s\n", sc6_repeat_scope, sc6_pass
}
' "$_RECORDS"

# Emit ABSENT lines
if [ -s "$_ABSENT" ]; then
  cat "$_ABSENT"
fi

exit 0
