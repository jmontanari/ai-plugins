@@ -0,0 +1,24 @@
+"""Integration tests — wires formatter → exporter → FakeArchive."""
+
+from src.report.formatter import format_data
+from src.report.exporter import export_archive
+
+
+class FakeArchive:
+    """Contract-tested double for the external ArchiveService."""
+
+    def __init__(self):
+        self.submitted = []
+
+    def submit(self, data):
+        self.submitted.append(data)
+
+
+class TestReportIntegration:
+    def test_export_pipeline(self):
+        """Wires format_data → export_archive → FakeArchive end-to-end."""  # [integration]
+        records = [{"id": "r1", "value": "alpha"}, {"id": "r2", "value": "beta"}]
+        lines = format_data(records)
+        fake = FakeArchive()
+        export_archive(lines, fake)
+        assert fake.submitted == [{"records": ["r1: alpha", "r2: beta"]}]
