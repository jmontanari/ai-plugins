--- /dev/null
+++ b/src/report/exporter.py
@@ -0,0 +1,25 @@
+"""Report exporter — submits formatted data to the archive service."""
+
+
+class ArchiveClient:
+    """Thin client wrapping the external ArchiveService API."""
+
+    def __init__(self, base_url):
+        self.base_url = base_url
+
+    def submit(self, data):
+        """Submit data payload to the archive service."""
+        import urllib.request
+        import json
+        req = urllib.request.Request(
+            f"{self.base_url}/submit",
+            data=json.dumps(data).encode(),
+            method="POST",
+        )
+        urllib.request.urlopen(req)
+
+
+def export_archive(data, client):
+    """Export formatted report data to the external archive service."""
+    client.submit({"records": data})
+
diff --git a/tests/test_archive_contract.py b/tests/test_archive_contract.py
new file mode 100644
index 0000000..c3d4e5f
--- /dev/null
+++ b/tests/test_archive_contract.py
@@ -0,0 +1,18 @@
+"""Contract tests — FakeArchive faithfully implements ArchiveService."""
+
+
+class FakeArchive:
+    """Test double for ArchiveService — captures submitted payloads."""
+
+    def __init__(self):
+        self.submitted = []
+
+    def submit(self, data):
+        self.submitted.append(data)
+
+
+class TestArchiveContract:
+    def test_fake_implements_submit(self):
+        """FakeArchive.submit accepts the same payload shape as ArchiveService."""
+        fake = FakeArchive()
+        fake.submit({"records": ["r1: alpha"]})
+        assert fake.submitted == [{"records": ["r1: alpha"]}]
+
