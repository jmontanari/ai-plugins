+"""Integration tests for the formatter pipeline."""
+import pytest
+from src.report.formatter import format_data, format_summary
+
+
+class TestFormatterIntegration:
+    """Integration tests — wires formatter.format_data → formatter.format_summary."""
+
+    def test_full_format_pipeline(self):
+        """format_data feeds into format_summary via the formatter module."""  # [integration]
+        records = [{"id": "r1", "value": "alpha"}, {"id": "r2", "value": "beta"}]
+        lines = format_data(records)
+        summary = format_summary(len(lines))
+        assert lines == ["r1: alpha", "r2: beta"]
+        assert summary == "Total: 2"
