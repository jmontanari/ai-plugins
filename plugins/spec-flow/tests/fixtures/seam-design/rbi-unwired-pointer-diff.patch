@@ -0,0 +1,18 @@
+"""Tests for report formatter."""
+import pytest
+from src.report.formatter import format_data, format_summary
+
+
+def test_format_data_single_record():
+    records = [{"id": "r1", "value": "hello"}]
+    result = format_data(records)
+    assert result == ["r1: hello"]
+
+
+def test_format_data_empty():
+    assert format_data([]) == []
+
+
+def test_format_summary():
+    assert format_summary(5) == "Total: 5"
