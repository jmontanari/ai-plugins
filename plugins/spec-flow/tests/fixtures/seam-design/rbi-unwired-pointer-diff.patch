+"""Report formatter — formats raw data for output."""
+
+
+def format_data(raw_records):
+    """Format a list of raw records into report lines."""
+    lines = []
+    for record in raw_records:
+        lines.append(f"{record['id']}: {record['value']}")
+    return lines
+
+
+def format_summary(total):
+    return f"Total: {total}"
